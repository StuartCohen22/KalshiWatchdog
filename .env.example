# === Storage backend ===
# "sqlite" for local dev, "dynamodb" for AWS Lambda
STORAGE_BACKEND=sqlite
LOCAL_DATA_DIR=/path/to/KalshiWatchdog/local_data

# === Kalshi API ===
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_RSA_KEY_PATH=/path/to/.kalshi/private_key.pem
# For Lambda: set KALSHI_RSA_KEY_PEM with the base64-encoded PEM instead

# === AI Analysis ===
# "bedrock" (Claude 3 Haiku via AWS) or "heuristic" (no LLM, rule-based)
ANALYSIS_BACKEND=bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
